# vLLM Manager Configuration
# Copy this file to .env and modify as needed

# Container runtime: "podman" or "docker"
CONTAINER_RUNTIME=podman

# Run with sudo (required for rootful podman to access GPU devices)
# Set to empty string to disable: USE_SUDO=
USE_SUDO=sudo

# Container name
CONTAINER_NAME=vllm-manager

# Image name (after building)
IMAGE_NAME=vllm-manager:latest

# Models directory on the host
MODELS_DIR=/home/ollama/vllm_models

# Admin UI port
ADMIN_PORT=7080

# vLLM API port range (one port per instance)
VLLM_PORT_START=8001
VLLM_PORT_END=8010

# Shared memory size (needed for multi-GPU tensor parallelism)
SHM_SIZE=16g

# Temp filesystem sizes
TMP_SIZE=1g
CACHE_SIZE=2g

# GPU devices to pass through (space-separated)
# Use "auto" to detect all NVIDIA GPUs automatically
GPU_DEVICES=auto

# NVIDIA driver library paths (auto-detected if empty)
# Override these if your driver libs are in a non-standard location
NVIDIA_ML_LIB=
CUDA_LIB=
NVPTX_LIB=

# Read-only container filesystem (true/false)
# Disable if vLLM needs to write to paths not covered by tmpfs mounts
READ_ONLY=true

# SELinux: set to "true" to add :Z label on volume mounts (RHEL/CentOS/Fedora)
SELINUX_LABEL=false

# Extra arguments passed to the container runtime
EXTRA_ARGS=
